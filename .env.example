# Copy this file to .env.local and fill in your own values.
# Every variable here is OPTIONAL for the site to run locally — they only
# enable specific features. The app starts and serves all pages without them.

# --- Email: powers the "Hire me to speak" contact form ---
# Read by app/api/send-email/route.ts. Without EMAIL_USER + EMAIL_PASSWORD the
# form still submits successfully, but no email is actually sent.
# For Gmail, create an App Password (requires 2FA): https://myaccount.google.com/security
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
# Optional "From" address; falls back to the submitter's email if unset.
EMAIL_FROM=noreply@humanfirst.app
# Note: the recipient address is currently hardcoded in app/api/send-email/route.ts,
# so there is no EMAIL_TO_ADDRESS variable to set here.

# --- Calendly: powers the "Book a 1-on-1 Meeting" widget ---
# Read by components/calendly-section.tsx. Without it, the widget will not render.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname/meeting
